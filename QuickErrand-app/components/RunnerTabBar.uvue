<template>
  <view class="runner-tabbar">
    <view
      class="tab-item"
      :class="{ active: active === 'home' }"
      @click="switchTab('home')"
    >
      <text class="tab-icon">📊</text>
      <text class="tab-text">首页</text>
    </view>
    <view
      class="tab-item"
      :class="{ active: active === 'orders' }"
      @click="switchTab('orders')"
    >
      <text class="tab-icon">📦</text>
      <text class="tab-text">订单</text>
    </view>
    <view
      class="tab-item"
      :class="{ active: active === 'message' }"
      @click="switchTab('message')"
    >
      <view class="tab-icon-wrapper">
        <text class="tab-icon">💬</text>
        <view 
          v-if="hasUnread" 
          class="tab-badge"
          :class="{ 'badge-dot': isDotMode }"
        >
          <text v-if="!isDotMode" class="tab-badge-text">{{ unreadText }}</text>
        </view>
      </view>
      <text class="tab-text">消息</text>
    </view>
    <view
      class="tab-item"
      :class="{ active: active === 'profile' }"
      @click="switchTab('profile')"
    >
      <text class="tab-icon">👤</text>
      <text class="tab-text">我的</text>
    </view>
  </view>
</template>

<script>
import { messageState, refreshUnreadCount, startUnreadPolling, stopUnreadPolling } from '@/store/message.uts'

export default {
  name: 'RunnerTabBar',
  props: {
    active: {
      type: String,
      default: 'home'
    }
  },
  computed: {
    hasUnread(): boolean {
      return messageState.totalUnread > 0
    },
    isDotMode(): boolean {
      return messageState.totalUnread === 1
    },
    unreadText(): string {
      const total = messageState.totalUnread
      if (total > 99) return '99+'
      if (total === 1) return ''
      return String(total)
    }
  },
  created() {
    refreshUnreadCount()
    startUnreadPolling()
  },
  unmounted() {
    stopUnreadPolling()
  },
  methods: {
    switchTab(tab: string) {
      if (tab === this.active) return
      if (tab === 'home') {
        uni.redirectTo({
          url: '/pages/runner/home'
        })
      } else if (tab === 'orders') {
        uni.redirectTo({
          url: '/pages/runner/pending-orders'
        })
      } else if (tab === 'message') {
        uni.redirectTo({
          url: '/subpkg/chat-list?fromRunnerTab=1'
        })
      } else if (tab === 'profile') {
        uni.redirectTo({
          url: '/pages/runner/profile'
        })
      }
    }
  }
}
</script>

<style scoped>
.runner-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(110rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #ffffff;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -4rpx 20rpx rgba(15, 23, 42, 0.08);
  border-top: 1rpx solid #e5e7eb;
  z-index: 999;
  box-sizing: border-box;
  overflow: visible;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 22rpx;
  overflow: visible;
}

.tab-icon {
  font-size: 34rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 22rpx;
}

.tab-item.active {
  color: #2563eb;
}

.tab-item.active .tab-icon {
  transform: translateY(-2rpx);
}

.tab-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.tab-badge {
  position: absolute;
  top: -4rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.4);
  animation: badge-pop 0.3s ease-out;
  z-index: 10;
}

.tab-badge.badge-dot {
  min-width: 16rpx;
  width: 16rpx;
  height: 16rpx;
  padding: 0;
  border-radius: 8rpx;
  top: -2rpx;
  right: -10rpx;
}

.tab-badge-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 1;
}

@keyframes badge-pop {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}
</style>

