  line-height: 1.5;
}

.announcement-item-content {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.8;
  margin-bottom: 16rpx;
  max-height: 4.8em;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.announcement-action {
  display: flex;
  justify-content: flex-end;
