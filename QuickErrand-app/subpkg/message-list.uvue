  z-index: 2;
  background: #ffffff;
  border-radius: 15rpx;
  transition: transform 0.1s ease;
}

.message-card {
  position: relative;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 15rpx;
  overflow: hidden;
}

.message-card.unread {
  background: #f0f9ff;
}

.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 15rpx 15rpx 0;
}

.delete-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.unread-badge {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
