  background: linear-gradient(135deg, #e0edff 0%, #d6e7ff 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(37, 99, 235, 0.2);
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.15);
