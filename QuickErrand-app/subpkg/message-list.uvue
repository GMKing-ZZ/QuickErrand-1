  border-radius: 20rpx;
}

.type-order {
  background: #e6f7ff;
}

.type-system {
  background: #fff7e6;
}

.type-chat {
  background: #f6ffed;
}

.type-icon {
  font-size: 28rpx;
}

.type-text {
  font-size: 24rpx;
  font-weight: bold;
}

.type-order .type-text {
  color: #1890ff;
}

.type-system .type-text {
  color: #fa8c16;
}

.type-chat .type-text {
  color: #52c41a;
}

.message-time {
