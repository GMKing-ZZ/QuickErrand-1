  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.loading-wrapper {
  padding: 200rpx 0;
  display: flex;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.empty-wrapper {
  padding: 200rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.messages-content {
  padding: 20rpx 24rpx 30rpx;
}

.announcement-block {
  margin-bottom: 30rpx;
}

.announcement-header {
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.announcement-title-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 8rpx;
}

.announcement-subtitle-text {
  display: block;
