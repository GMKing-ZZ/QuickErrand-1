  color: #6b7280;
}

.announcement-list {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f0f0f0;
}

.announcement-item {
  position: relative;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid transparent;
  transition: all 0.3s ease;
}

.announcement-item:last-child {
  margin-bottom: 0;
}

.announcement-item.unread {
  background: #f0f9ff;
  border-left-color: #2563eb;
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.1);
}

.announcement-item.unread .announcement-item-title {
  color: #111827;
  font-weight: 600;
}

.announcement-main {
  flex: 1;
  min-width: 0;
}

.announcement-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12rpx;
}

.announcement-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ef4444;
  margin-right: 12rpx;
  flex-shrink: 0;
