  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  letter-spacing: 1rpx;
}

.placeholder {
  width: 64rpx;
  flex-shrink: 0;
}

/* 地图容器 */
.map-wrapper {
  flex: 1;
  position: relative;
  width: 100%;
  overflow: hidden;
}

.map {
  width: 100%;
  height: 100%;
}

/* 中心点标记 */
.center-marker {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -100%);
  z-index: 10;
  pointer-events: none;
}

.marker-icon {
  font-size: 60rpx;
  line-height: 1;
  text-align: center;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.3));
}

/* 底部地址信息 */
.address-info {
  background: #ffffff;
  padding: 30rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.address-header {
  margin-bottom: 20rpx;
}

.address-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.address-content {
  margin-bottom: 30rpx;
  min-height: 80rpx;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.address-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  word-break: break-all;
}

.address-text.placeholder {
  color: #999999;
}

.address-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  background: #f3f4f6;
  color: #666666;
}

.cancel-btn:active {
  background: #e5e7eb;
}

.confirm-btn {
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.confirm-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.confirm-btn[disabled] {
  opacity: 0.6;
}

/* 加载提示 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  background: #ffffff;
  padding: 40rpx 60rpx;
  border-radius: 16rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #333333;
}
</style>