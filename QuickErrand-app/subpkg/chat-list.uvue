  color: #ffffff;
}

.contact-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.contact-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.contact-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-text {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.contact-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 4rpx;
}

.last-msg {
  flex: 1;
