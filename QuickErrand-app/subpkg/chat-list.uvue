  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  white-space: nowrap;
}

.placeholder {
  width: 64rpx;
}

.loading-wrapper {
  padding: 200rpx 0;
  display: flex;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.empty-wrapper {
  padding: 200rpx 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #4b5563;
  font-weight: 500;
}

.empty-sub {
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
}

.list-scroll {
  padding: 16rpx 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 30rpx);
  box-sizing: border-box;
}

.contact-item-wrapper {
  position: relative;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.contact-item-swipe {
  position: relative;
  z-index: 2;
  background: #ffffff;
  border-radius: 18rpx;
  transition: transform 0.1s ease;
}

.contact-item {
  flex-direction: row;
  display: flex;
  padding: 20rpx 16rpx;
  background: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
}

.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 18rpx 18rpx 0;
}

.delete-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.contact-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.contact-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.contact-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-text {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.contact-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 4rpx;
}

.last-msg {
  flex: 1;
  font-size: 26rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.last-msg-empty {
  color: #9ca3af;
}

.unread-badge {
  margin-left: 12rpx;
  min-width: 32rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
}

.unread-text {
  font-size: 22rpx;
  color: #ffffff;
}
</style>
