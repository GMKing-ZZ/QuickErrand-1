  padding: 16rpx 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 30rpx);
  box-sizing: border-box;
}

.contact-item {
  flex-direction: row;
  display: flex;
  padding: 20rpx 16rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
}

.avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  display: flex;
