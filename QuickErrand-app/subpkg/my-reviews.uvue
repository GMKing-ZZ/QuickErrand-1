  padding-top: env(safe-area-inset-top);
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 50%, #60a5fa 100%);
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.25);
}

