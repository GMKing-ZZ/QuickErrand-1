<template>
  <view class="reviews-container">
    <!-- 导航栏 -->
    <view class="navbar">
      <view class="navbar-inner">
        <view class="back-btn" @click="goBack">
          <text class="back-icon">‹</text>
        </view>
        <text class="nav-title">我的评价</text>
        <view class="right-placeholder"></view>
      </view>
    </view>

    <!-- 评价列表 -->
    <view class="reviews-list">
      <view v-if="loading" class="loading-wrapper">
        <text class="loading-text">加载中...</text>
      </view>

      <view v-else-if="reviewList.length === 0" class="empty-wrapper">
        <text class="empty-text">暂无评价记录</text>
      </view>

      <view v-else>
        <view
          v-for="review in reviewList"
          :key="review.id"
          class="review-item"
          @click="goToOrderDetail(review.orderId)"
        >
          <view class="review-header">
            <text class="order-no">订单编号：{{ review.orderNo }}</text>
            <text class="review-time">{{ formatTime(review.createTime) }}</text>
          </view>

          <view class="review-content">
            <view class="runner-info">
              <text class="runner-label">跑腿员：</text>
              <text class="runner-name">{{ review.runnerName || '未知' }}</text>
            </view>

            <view class="score-section">
              <view class="score-item">
                <text class="score-label">服务质量：</text>
                <view class="stars">
                  <text
                    v-for="star in 5"
                    :key="star"
                    class="star"
                    :class="{ active: star <= review.serviceScore }"
                  >★</text>
                </view>
              </view>
              <view class="score-item">
                <text class="score-label">服务态度：</text>
                <view class="stars">
                  <text
                    v-for="star in 5"
                    :key="star"
                    class="star"
                    :class="{ active: star <= review.attitudeScore }"
                  >★</text>
                </view>
              </view>
            </view>

            <view v-if="review.tags && parseTags(review.tags).length > 0" class="review-tags">
              <view
                v-for="(tag, index) in parseTags(review.tags)"
                :key="index"
                class="tag-item"
              >
                <text class="tag-text">{{ tag }}</text>
              </view>
            </view>

            <view v-if="review.content" class="review-text">
              <text class="text-content">{{ review.content }}</text>
            </view>

            <view v-if="review.images" class="review-images">
              <image
                v-for="(img, index) in parseImages(review.images)"
                :key="index"
                class="review-image"
                :src="img"
                mode="aspectFill"
                @click.stop="previewImage(img, parseImages(review.images))"
              />
            </view>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view v-if="hasMore && !loading" class="load-more" @click="loadMore">
        <text class="load-more-text">加载更多</text>
      </view>
      <view v-if="!hasMore && reviewList.length > 0" class="no-more">
        <text class="no-more-text">没有更多了</text>
      </view>
    </view>
  </view>
</template>

<script>
import { getMyReviews, type ReviewInfo } from '@/common/api/user.uts'

export default {
  data() {
    return {
      reviewList: [] as ReviewInfo[],
      loading: false,
      pageNum: 1,
      pageSize: 10,
      total: 0,
      hasMore: true
    }
  },
  onLoad() {
    this.loadReviews()
  },
  onPullDownRefresh() {
    this.pageNum = 1
    this.hasMore = true
    this.loadReviews()
  },
  methods: {
    async loadReviews() {
      if (this.loading) return
      if (!this.hasMore && this.pageNum > 1) return

      this.loading = true
      try {
        const res = await getMyReviews(this.pageNum, this.pageSize)
        this.total = res.total

        if (this.pageNum === 1) {
          this.reviewList = res.records
        } else {
          this.reviewList = this.reviewList.concat(res.records)
        }

        this.hasMore = this.reviewList.length < this.total
      } catch (error) {
        console.error('获取评价列表失败:', error)
        uni.showToast({
          title: '加载失败，请重试',
          icon: 'none'
        })
      } finally {
        this.loading = false
        uni.stopPullDownRefresh()
      }
    },

    loadMore() {
      if (!this.hasMore || this.loading) return
      this.pageNum++
      this.loadReviews()
    },

    goBack() {
      uni.navigateBack()
    },

    goToOrderDetail(orderId: number) {
      uni.navigateTo({
        url: `/subpkg/order-detail?orderId=${orderId}`
      })
    },

    formatTime(time: string): string {
      if (!time) return ''
      const date = new Date(time)
      const year = date.getFullYear()
      const month = String(date.getMonth() + 1).padStart(2, '0')
      const day = String(date.getDate()).padStart(2, '0')
      const hour = String(date.getHours()).padStart(2, '0')
      const minute = String(date.getMinutes()).padStart(2, '0')
      return `${year}-${month}-${day} ${hour}:${minute}`
    },

    parseImages(images: string): string[] {
      if (!images) return []
      try {
        return JSON.parse(images)
      } catch (e) {
        return []
      }
    },

    parseTags(tags: string): string[] {
      if (!tags) return []
      try {
        return JSON.parse(tags)
      } catch (e) {
        return []
      }
    },

    previewImage(current: string, urls: string[]) {
      uni.previewImage({
        current: current,
        urls: urls
      })
    }
  }
}
</script>

<style scoped>
