.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.review-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.review-time {
  font-size: 24rpx;
  color: #999999;
}

.review-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.runner-info {
  display: flex;
  align-items: center;
  flex-direction: row;
  width: 100%;
}

.runner-label {
  font-size: 26rpx;
  color: #666666;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.runner-name {
  font-size: 26rpx;
  color: #2563eb;
  font-weight: 500;
  flex: 1;
}

.score-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
}

.score-item {
  display: flex;
  align-items: center;
  flex-direction: row;
  width: 100%;
}

.score-label {
  font-size: 26rpx;
  color: #666666;
  margin-right: 12rpx;
  flex-shrink: 0;
  width: 120rpx;
}

.stars {
  display: flex;
  flex-direction: row;
  gap: 4rpx;
  align-items: center;
}

.star {
  font-size: 28rpx;
  color: #e0e0e0;
  line-height: 1;
}

.star.active {
  color: #ffd700;
}

