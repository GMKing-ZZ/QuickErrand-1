}

.review-text {
  background: #f9fafb;
  padding: 20rpx;
  border-radius: 12rpx;
}

.text-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.review-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.review-image {
  width: 160rpx;
