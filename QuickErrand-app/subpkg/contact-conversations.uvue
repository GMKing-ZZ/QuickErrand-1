  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.last-msg {
  flex: 1;
  font-size: 26rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.last-msg-empty {
  color: #9ca3af;
}

.time-text {
  font-size: 22rpx;
  color: #9ca3af;
  flex-shrink: 0;
}

.unread-badge {
  min-width: 32rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
}

.unread-text {
  font-size: 22rpx;
  color: #ffffff;
}
</style>
