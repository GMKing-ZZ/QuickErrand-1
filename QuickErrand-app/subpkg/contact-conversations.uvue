}

.status-serving {
  background: #d1fae5;
  color: #059669;
}

.status-completed {
  background: #f3f4f6;
  color: #6b7280;
}

.status-cancelled {
  background: #fee2e2;
  color: #dc2626;
}

.order-title {
  font-size: 28rpx;
  color: #111827;
