  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: row;
  align-items: center;
}

.avatar-small {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  margin-right: 12rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-small-img {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.avatar-small-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-small-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffffff;
  white-space: nowrap;
}

.placeholder {
  width: 64rpx;
}

.loading-wrapper {
  padding: 200rpx 0;
  display: flex;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.empty-wrapper {
  padding: 200rpx 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #4b5563;
  font-weight: 500;
}

.list-scroll {
  padding: 16rpx 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 30rpx);
  box-sizing: border-box;
}

.order-item-wrapper {
  position: relative;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.order-item-swipe {
  position: relative;
  z-index: 2;
  background: #ffffff;
  border-radius: 18rpx;
  transition: transform 0.1s ease;
}

.order-item {
  flex-direction: row;
  display: flex;
  padding: 20rpx 16rpx;
  background: #ffffff;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
  align-items: center;
}

.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 18rpx 18rpx 0;
}

.delete-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.order-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.order-no {
  font-size: 24rpx;
  color: #6b7280;
}

.order-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-pending {
  background: #fef3c7;
  color: #d97706;
}

.status-waiting {
  background: #dbeafe;
