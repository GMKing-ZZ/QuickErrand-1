<template>
  <view class="conversations-container">
    <!-- 导航栏 -->
    <view class="navbar">
      <view class="back-btn" @click="goBack">
        <text class="back-icon">‹</text>
      </view>
      <view class="nav-title-wrapper">
        <view class="avatar-small">
          <image
            v-if="contactAvatar"
            class="avatar-small-img"
            :src="contactAvatar"
            mode="aspectFill"
          />
          <view v-else class="avatar-small-placeholder">
            <text class="avatar-small-text">{{ (contactNickname || '聊').charAt(0) }}</text>
          </view>
        </view>
        <text class="nav-title">{{ contactNickname || '聊天' }}</text>
      </view>
      <view class="placeholder"></view>
    </view>

    <!-- 加载中 -->
    <view v-if="loading" class="loading-wrapper">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view v-else-if="conversations.length === 0" class="empty-wrapper">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无订单聊天</text>
    </view>

    <!-- 订单会话列表 -->
    <scroll-view v-else class="list-scroll" scroll-y enable-back-to-top>
      <view
        v-for="(item, index) in conversations"
        :key="item.orderId"
        class="order-item-wrapper"
      >
        <view
          class="order-item-swipe"
          :style="{ transform: `translateX(${item._translateX || 0}px)` }"
          @touchstart="onTouchStart($event, index)"
          @touchmove="onTouchMove($event, index)"
          @touchend="onTouchEnd($event, index)"
        >
          <view class="order-item" @click="openChatSession(item)">
            <view class="order-info">
              <view class="order-header">
                <text class="order-no">订单号: {{ item.orderNo }}</text>
                <text class="order-status" :class="getStatusClass(item.orderStatus)">
                  {{ getStatusText(item.orderStatus) }}
                </text>
              </view>
              <text class="order-title" v-if="item.orderTitle">{{ item.orderTitle }}</text>
              <view class="order-footer">
                <text class="last-msg" :class="{ 'last-msg-empty': !item.lastContent }">
                  {{ formatLastContent(item.lastContent) }}
                </text>
                <text class="time-text" v-if="item.lastTime">{{ formatTime(item.lastTime) }}</text>
              </view>
            </view>
            <view v-if="item.unreadCount > 0" class="unread-badge">
              <text class="unread-text">
                {{ item.unreadCount > 99 ? '99+' : String(item.unreadCount) }}
              </text>
            </view>
          </view>
        </view>
        <view class="delete-btn" @click="confirmDelete(item, index)">
          <text class="delete-btn-text">删除</text>
        </view>
      </view>
    </scroll-view>
  </view>
</template>

<script>
import type { ChatOrderConversation } from '@/common/api/chat.uts'
import { getContactOrderConversations, deleteOrderConversation } from '@/common/api/chat.uts'

const DELETE_BTN_WIDTH = 70

export default {
  data() {
    return {
      loading: true,
      contactId: 0 as number,
      contactNickname: '' as string,
      contactAvatar: '' as string,
      conversations: [] as ChatOrderConversation[],
      startX: 0,
      startY: 0,
      currentIndex: -1
    }
  },
  onLoad(options: any) {
    if (options && options.contactId) {
      this.contactId = Number(options.contactId)
    }
    if (options && options.nickname) {
      this.contactNickname = decodeURIComponent(options.nickname)
    }
    if (options && options.avatar) {
      this.contactAvatar = decodeURIComponent(options.avatar)
    }
    this.loadConversations()
  },
  onShow() {
    this.loadConversations()
  },
  methods: {
    goBack() {
      uni.navigateBack()
    },

    async loadConversations() {
      if (!this.contactId) return
      this.loading = true
      try {
        const list = await getContactOrderConversations(this.contactId)
        this.conversations = (list || []).map((item: ChatOrderConversation) => {
          return {
            ...item,
            _translateX: 0
          } as any
        })
      } catch (error) {
        console.error('获取订单聊天列表失败:', error)
        uni.showToast({
          title: '加载失败，请重试',
          icon: 'none'
        })
      } finally {
        this.loading = false
      }
    },

    onTouchStart(e: TouchEvent, index: number) {
      if (e.touches.length > 0) {
        this.startX = e.touches[0].clientX
        this.startY = e.touches[0].clientY
        if (this.currentIndex !== index && this.currentIndex >= 0) {
          this.closeSwipe(this.currentIndex)
        }
        this.currentIndex = index
      }
    },

    onTouchMove(e: TouchEvent, index: number) {
      if (e.touches.length > 0) {
        const moveX = e.touches[0].clientX - this.startX
        const moveY = e.touches[0].clientY - this.startY
        if (Math.abs(moveY) > Math.abs(moveX)) {
          return
        }
        const item = this.conversations[index] as any
        let translateX = (item._translateX || 0) + moveX
        if (translateX > 0) translateX = 0
        if (translateX < -DELETE_BTN_WIDTH) translateX = -DELETE_BTN_WIDTH
        item._translateX = translateX
        this.startX = e.touches[0].clientX
      }
    },

    onTouchEnd(e: TouchEvent, index: number) {
      const item = this.conversations[index] as any
      const translateX = item._translateX || 0
      if (translateX < -DELETE_BTN_WIDTH / 2) {
        item._translateX = -DELETE_BTN_WIDTH
      } else {
        item._translateX = 0
      }
    },

    closeSwipe(index: number) {
      const item = this.conversations[index] as any
      if (item) {
        item._translateX = 0
      }
    },

    confirmDelete(item: ChatOrderConversation, index: number) {
      uni.showModal({
        title: '确认删除',
        content: `确定删除订单 ${item.orderNo} 的聊天记录吗？删除后您将无法看到之前的聊天记录，但对方不受影响。`,
        success: (res) => {
          if (res.confirm) {
            this.doDelete(item, index)
          } else {
            this.closeSwipe(index)
          }
        }
      })
    },

    async doDelete(item: ChatOrderConversation, index: number) {
      try {
        await deleteOrderConversation(this.contactId, item.orderId)
        this.conversations.splice(index, 1)
        this.currentIndex = -1
        uni.showToast({
          title: '删除成功',
          icon: 'success'
        })
      } catch (error) {
        console.error('删除订单会话失败:', error)
        uni.showToast({
          title: '删除失败，请重试',
          icon: 'none'
        })
        this.closeSwipe(index)
      }
    },

    openChatSession(item: ChatOrderConversation) {
      if (!item || !item.orderId) return
      const translateX = (item as any)._translateX || 0
      if (translateX < 0) {
        this.closeSwipe(this.conversations.indexOf(item))
        return
      }
      uni.navigateTo({
        url: `/subpkg/chat-session?orderId=${item.orderId}`
      })
    },

    getStatusClass(status: number): string {
      switch (status) {
        case 1: return 'status-pending'
        case 2: return 'status-waiting'
        case 3: return 'status-serving'
        case 4: return 'status-completed'
        case 5: return 'status-cancelled'
        default: return ''
      }
    },

    getStatusText(status: number): string {
      switch (status) {
        case 1: return '待支付'
        case 2: return '待接单'
        case 3: return '服务中'
        case 4: return '已完成'
        case 5: return '已取消'
        default: return '未知'
      }
    },

    formatTime(ts: number): string {
      if (!ts) return ''
      const time = new Date(ts)
      const now = new Date()
      const diff = now.getTime() - time.getTime()

      if (diff < 60000) {
        return '刚刚'
      }
      if (diff < 3600000) {
        return Math.floor(diff / 60000) + '分钟前'
      }

      const todayStr = now.toDateString()
      const timeStr = time.toDateString()
      if (timeStr === todayStr) {
        const h = time.getHours()
        const m = String(time.getMinutes()).padStart(2, '0')
        return `${h}:${m}`
      }

      const yesterday = new Date(now)
      yesterday.setDate(yesterday.getDate() - 1)
      if (timeStr === yesterday.toDateString()) {
        const h = time.getHours()
        const m = String(time.getMinutes()).padStart(2, '0')
        return `昨天 ${h}:${m}`
      }

      const month = time.getMonth() + 1
      const date = time.getDate()
      return `${month}-${date}`
    },

    formatLastContent(content: string): string {
      if (!content) return '暂无聊天记录'
      if (this.isImageUrl(content)) return '[图片]'
      if (content.length > 30) return content.substring(0, 30) + '...'
      return content
    },

    isImageUrl(url: string): boolean {
      if (!url) return false
      const lower = url.toLowerCase()
      return lower.match(/\.(jpg|jpeg|png|gif|webp|bmp|svg)(\?.*)?$/i) !== null ||
             lower.includes('/image') ||
             lower.includes('/images') ||
             lower.includes('/upload')
    }
  }
}
</script>

<style scoped>
.conversations-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.navbar {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 60rpx 30rpx 20rpx;
  padding-top: calc(60rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 50%, #60a5fa 100%);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
}

