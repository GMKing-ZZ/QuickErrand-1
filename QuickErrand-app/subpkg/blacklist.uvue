  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.list-section {
  padding: 24rpx 30rpx;
}

.runner-card {
  background: var(--list-background-color, #ffffff);
  border-radius: 20rpx;
  padding: 30rpx;
