<template>
  <view class="blacklist-container">
    <view class="navbar">
      <view class="back-btn" @click="goBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="nav-title">被拉黑跑腿员</text>
      <view class="placeholder"></view>
    </view>

    <scroll-view class="content-scroll" scroll-y enable-back-to-top>
      <view v-if="loading" class="loading-section">
        <text class="loading-text">加载中...</text>
      </view>

      <view v-else-if="blacklist.length > 0" class="list-section">
        <view 
          v-for="item in blacklist" 
          :key="item.id" 
          class="runner-card"
        >
          <view class="runner-header" @click="goRunnerProfile(item.runnerId)">
            <image 
              class="runner-avatar" 
              :src="item.runnerAvatar || '/static/logo.png'" 
              mode="aspectFill"
            />
            <view class="runner-info">
              <text class="runner-name">{{ item.runnerName }}</text>
              <view class="runner-stats">
                <view class="star-list">
                  <text
                    v-for="n in 5"
                    :key="n"
                    class="star"
                    :class="{ active: n <= item.creditLevel }"
                  >
                    ★
                  </text>
                </view>
                <text class="stat-text">完成 {{ item.totalOrders }} 单</text>
                <text class="stat-text">好评率 {{ formatGoodRate(item.goodRate) }}%</text>
              </view>
            </view>
          </view>
          <view class="runner-footer">
            <text class="blacklist-time">拉黑时间：{{ formatTime(item.createTime) }}</text>
            <button class="unblock-btn" @click="handleUnblock(item)">
              <text class="unblock-btn-text">解除屏蔽</text>
            </button>
          </view>
        </view>
      </view>

      <view v-else class="empty-section">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无被拉黑的跑腿员</text>
      </view>
    </scroll-view>
  </view>
</template>

<script>
import { getBlacklist, removeFromBlacklist, type BlacklistedRunnerInfo } from '@/common/api/blacklist.uts'

export default {
  data() {
    return {
      loading: false,
      blacklist: [] as BlacklistedRunnerInfo[]
    }
  },
  onShow() {
    this.loadBlacklist()
  },
  methods: {
    async loadBlacklist() {
      try {
        this.loading = true
        const res = await getBlacklist()
        this.blacklist = res
      } catch (error) {
        console.error('获取黑名单失败:', error)
        uni.showToast({
          title: '加载失败',
          icon: 'none'
        })
      } finally {
        this.loading = false
      }
    },

    goBack() {
      uni.navigateBack()
    },

    goRunnerProfile(runnerId: number) {
      uni.navigateTo({
        url: `/subpkg/runner-profile?runnerUserId=${runnerId}`
      })
    },

    formatGoodRate(rate: number): string {
      if (rate === null || rate === undefined) return '0.0'
      return rate.toFixed(1)
    },

    formatTime(time: string): string {
      if (!time) return ''
      return time.replace('T', ' ').substring(0, 19)
    },

    handleUnblock(item: BlacklistedRunnerInfo) {
      uni.showModal({
        title: '解除屏蔽',
        content: `确定要解除对 ${item.runnerName} 的屏蔽吗？解除后该跑腿员可以接您的订单。`,
        success: async (res) => {
          if (res.confirm) {
            try {
              await removeFromBlacklist(item.runnerId)
              uni.showToast({
                title: '已解除屏蔽',
                icon: 'success'
              })
              this.loadBlacklist()
            } catch (error) {
              console.error('解除屏蔽失败:', error)
              uni.showToast({
                title: '操作失败',
                icon: 'none'
              })
            }
          }
        }
      })
    }
  }
}
</script>

