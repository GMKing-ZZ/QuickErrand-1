<script lang="uts">
import { setAgreeToPrivacy } from '@/store/index.uts'
export default {
  data() {
    return {
      fromLogin: false
    }
  },
  onLoad(options: UTSJSONObject) {
    const from = options['from'] as string
    if (from === 'login') {
      this.fromLogin = true
    }
  },
  methods: {
    onAgree() {
      setAgreeToPrivacy(true)
      uni.navigateBack({})
    }
  }
}
</script>

