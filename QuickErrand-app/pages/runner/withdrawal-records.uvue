  font-size: 28rpx;
  color: #999999;
}

/* 空状态 */
.empty-wrapper {
  padding: 200rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 记录列表 */
.records-list {
  padding: 30rpx;
}

.record-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 26rpx 30rpx;
  background: #ffffff;
  border-radius: 0;
  border-bottom: 1rpx solid #f1f1f5;
}

.record-row:last-child {
  border-bottom-width: 0;
}

.col-index {
  width: 80rpx;
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
}

.col-two-lines {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
}

.line-first,
.line-second {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.first-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.account-type {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.method-text {
  font-size: 28rpx;
  color: #111827;
}

.status-pill {
  display: flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.status-pending {
  background: #fff3cd;
  color: #856404;
}

.status-approved {
  background: #d1ecf1;
  color: #0c5460;
}

.status-rejected {
  background: #f8d7da;
  color: #721c24;
}

.status-completed {
  background: #d4edda;
  color: #155724;
}

.account-info-text {
  font-size: 26rpx;
