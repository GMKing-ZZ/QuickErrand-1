<template>
  <view class="withdrawal-records-container">
    <!-- 导航栏 -->
    <view class="navbar">
      <view class="back-btn" @click="goBack">
        <text class="back-icon">←</text>
      </view>
      <text class="nav-title">提现记录</text>
      <view class="placeholder"></view>
    </view>

    <!-- 加载中 -->
    <view v-if="loading" class="loading-wrapper">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view v-else-if="records.length === 0" class="empty-wrapper">
      <text class="empty-icon">💸</text>
      <text class="empty-text">暂无提现记录</text>
    </view>

    <!-- 提现记录列表（参照收益明细的表格样式） -->
    <view v-else class="records-list">
      <view
        v-for="(record, index) in records"
        :key="record.id"
        class="record-row"
      >
        <!-- 序号 -->
        <text class="col-index">{{ formatIndex(index) }}</text>

        <!-- 主内容：两行，全部居左 -->
        <view class="col-two-lines">
          <!-- 第一行：提现方式 + （审核状态 + 提现金额） -->
          <view class="line-first">
            <text class="method-text">{{ record.accountTypeText }}</text>
            <view class="first-right">
              <text
                class="status-pill"
                :class="getStatusClass(record.status)"
              >
                {{ record.statusText }}
              </text>
              <text class="amount-text">
                ¥{{ record.actualAmount || record.amount }}
              </text>
            </view>
          </view>

          <!-- 第二行：提现账户 + 申请时间 -->
          <view class="line-second">
            <text class="account-text">{{ record.accountInfo }}</text>
            <text class="time-text">{{ formatTime(record.createTime) }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</template>

<script>
import { getWithdrawalRecords } from '@/common/api/runner.uts'
import { formatDateTime } from '@/common/utils/common.uts'

export default {
  data() {
    return {
      loading: true,
      records: [] as any[]
    }
  },
  onLoad() {
    this.loadRecords()
  },
  methods: {
    formatTime(time: string | null | undefined): string {
      if (!time) return ''
      return formatDateTime(time)
    },
    goBack() {
      uni.navigateBack()
    },

    async loadRecords() {
      this.loading = true
      try {
        this.records = await getWithdrawalRecords()
      } catch (error) {
        console.error('获取提现记录失败:', error)
        uni.showToast({
          title: '加载失败，请重试',
          icon: 'none'
        })
      } finally {
        this.loading = false
      }
    },

    getAccountIcon(accountType: number): string {
      // 与提现页保持一致：2-微信 3-银行卡，其它使用通用图标
      switch (accountType) {
        case 2:
          return '/static/weixinzhifu.png'
        case 3:
          return '/static/yinlian.png'
        default:
          return '/static/yinlian.png'
      }
    },

    getStatusClass(status: number): string {
      switch (status) {
        case 1:
          return 'status-pending'
        case 2:
          return 'status-approved'
        case 3:
          return 'status-rejected'
        case 4:
          return 'status-completed'
        default:
          return ''
      }
    },

    // 列表序号格式：01、02...
    formatIndex(index: number): string {
      const num = index + 1
      return num < 10 ? `0${num}` : `${num}`
    }
  }
}
</script>

<style scoped>
.withdrawal-records-container {
  min-height: 100vh;
  background: #f9fafb;
}

