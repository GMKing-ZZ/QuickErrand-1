  min-height: 100vh;
  background: #f3f4f6;
  display: flex;
  flex-direction: column;
}

.navbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 60rpx 30rpx 20rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 50%, #60a5fa 100%);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.placeholder {
  width: 64rpx;
}

.content {
  flex: 1;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.order-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx 18rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
}

.order-no,
.order-type,
.order-route,
.order-amount-label {
  display: block;
  font-size: 26rpx;
  color: #111827;
  margin-bottom: 8rpx;
}

.order-amount-label {
  font-size: 26rpx;
  color: #111827;
}

.order-amount-value {
  font-weight: 700;
  font-size: 30rpx;
  color: #ef4444; /* 与订单详情页实付金额高亮色保持一致 */
}

.code-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 40rpx;
}

.code-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.code-input {
  margin-top: 16rpx;
  width: 100%;
  height: 80rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #111827;
}

.code-tip {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  border: none;
  /* 与小程序主题一致的蓝色主按钮样式 */
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 55%, #60a5fa 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(37, 99, 235, 0.4);
}

.confirm-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}
</style>

