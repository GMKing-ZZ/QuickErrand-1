  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  border-radius: 40rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

/* 内容区域 */
.content-wrapper {
  padding: 30rpx;
}

/* 状态卡片 */
.status-card {
  padding: 40rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.status-header {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

