}

/* 照片区域 */
.photos-wrapper {
  display: flex;
  gap: 30rpx;
}

.photo-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.photo-image {
  width: 100%;
  height: 300rpx;
  border-radius: 15rpx;
}

.photo-label {
  font-size: 26rpx;
  color: #666666;
  text-align: center;
}

/* 操作区域 */
.action-section {
  padding: 30rpx;
}

.reapply-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  border-radius: 50rpx;
