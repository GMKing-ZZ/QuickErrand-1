  font-size: 80rpx;
}

.status-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.status-title {
  font-size: 36rpx;
  font-weight: bold;
}

.status-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.status-pending {
  border-left: 8rpx solid #ffc107;
}

.status-pending .status-title {
  color: #ffc107;
}

.status-approved {
  border-left: 8rpx solid #4caf50;
}

.status-approved .status-title {
  color: #4caf50;
}

.status-rejected {
  border-left: 8rpx solid #f44336;
}

.status-rejected .status-title {
  color: #f44336;
}

/* 信息区域 */
.info-section,
.photos-section,
.runner-section {
  padding: 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
}

.info-line {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-line:last-child {
  border-bottom-width: 0;
}

