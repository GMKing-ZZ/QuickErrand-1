<template>
  <view class="auth-apply-container">
    <!-- 头部背景，样式与用户端编辑资料保持一致 -->
    <view class="header-bg">
      <view class="wave"></view>
    </view>

    <!-- 导航栏 -->
    <view class="navbar">
      <view class="back-btn" @click="goBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="nav-title">{{ isReapply ? '重新认证申请' : '跑腿员认证申请' }}</text>
      <view class="placeholder"></view>
    </view>

    <!-- 提示信息 -->
    <view class="tips-section">
      <text class="tips-icon">ℹ️</text>
      <view class="tips-content">
        <text class="tips-title">{{ isReapply ? '重新认证说明' : '认证说明' }}</text>
        <text class="tips-text">1. 请确保提供的信息真实有效</text>
        <text class="tips-text">2. 身份证照片需清晰可见</text>
        <text class="tips-text">3. 提交后等待管理员审核，审核通过后即可接单</text>
        <text class="tips-text" v-if="isReapply">4. 请检查并修改有误的信息后重新提交</text>
        <text class="tips-text" v-else>4. 未通过认证的跑腿员无法接单</text>
      </view>
    </view>

    <!-- 表单区域 -->
    <view class="form-section">
      <!-- 真实姓名 -->
      <view class="form-item">
        <text class="form-label">真实姓名</text>
        <input
          class="form-input"
          v-model="formData.realName"
          placeholder="请输入真实姓名"
          maxlength="50"
        />
      </view>

      <!-- 身份证号 -->
      <view class="form-item">
        <text class="form-label">身份证号</text>
        <input
          class="form-input"
          v-model="formData.idCard"
          placeholder="请输入身份证号"
          maxlength="18"
        />
      </view>

      <!-- 身份证正面照 -->
      <view class="form-item">
        <text class="form-label">身份证正面照</text>
        <view class="upload-wrapper">
          <view
            v-if="!formData.idCardFront"
            class="upload-box"
            @click="uploadIdCardFront"
          >
            <text class="upload-icon">+</text>
            <text class="upload-text">上传身份证正面</text>
          </view>
          <view v-else class="image-preview" @click="uploadIdCardFront">
            <image class="preview-image" :src="formData.idCardFront" mode="aspectFill" />
            <view class="delete-btn" @click.stop="deleteIdCardFront">
              <text class="delete-icon">×</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 身份证反面照 -->
      <view class="form-item">
        <text class="form-label">身份证反面照</text>
        <view class="upload-wrapper">
          <view
            v-if="!formData.idCardBack"
            class="upload-box"
            @click="uploadIdCardBack"
          >
            <text class="upload-icon">+</text>
            <text class="upload-text">上传身份证反面</text>
          </view>
          <view v-else class="image-preview" @click="uploadIdCardBack">
            <image class="preview-image" :src="formData.idCardBack" mode="aspectFill" />
            <view class="delete-btn" @click.stop="deleteIdCardBack">
              <text class="delete-icon">×</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button class="submit-btn" @click="handleSubmit" :loading="submitting">
        <text class="btn-text">{{ isReapply ? '重新提交申请' : '提交申请' }}</text>
      </button>
    </view>
  </view>
</template>

<script>
import { applyRunnerAuth, getRunnerAuthInfo } from '@/common/api/runner.uts'
import { userState } from '@/store/user.uts'
import { upload } from '@/common/utils/request.uts'

export default {
  data() {
    return {
      formData: {
        realName: '',
        idCard: '',
        idCardFront: '',
        idCardBack: ''
      },
      submitting: false,
      isReapply: false
    }
  },
  onLoad(options: any) {
    if (options.reapply === 'true') {
      this.isReapply = true
      this.loadExistingAuthInfo()
    }
  },
  methods: {
    async loadExistingAuthInfo() {
      try {
        uni.showLoading({ title: '加载中...' })
        const authInfo = await getRunnerAuthInfo()
        if (authInfo) {
          this.formData.realName = authInfo.realName || ''
          this.formData.idCardFront = authInfo.idCardFront || ''
          this.formData.idCardBack = authInfo.idCardBack || ''
          if (authInfo.idCard && !authInfo.idCard.includes('*')) {
            this.formData.idCard = authInfo.idCard
          }
        }
        uni.hideLoading()
      } catch (error) {
        uni.hideLoading()
        console.error('加载已有认证信息失败:', error)
      }
    },
    goBack() {
      uni.navigateBack()
    },

    // 进入页面前校验身份
    checkRunnerAccess() {
      const info: any = userState.userInfo
      if (!info || info.userType !== 2) {
        uni.showModal({
          title: '提示',
          content: '当前账号不是跑腿员，无法申请跑腿员认证',
          showCancel: false,
          success: () => {
            uni.navigateBack()
          }
        })
        return false
      }
      return true
    },

    // 上传身份证正面照
    uploadIdCardFront() {
      uni.chooseImage({
        count: 1,
        sizeType: ['compressed'],
        sourceType: ['album', 'camera'],
        success: async (res) => {
          const tempFilePath = res.tempFilePaths[0]

          uni.showLoading({
            title: '上传中...'
          })

          try {
            const info: any = userState.userInfo
            const username = info?.username || 'user'
            const uploadRes = await upload('/file/upload/runner-auth', tempFilePath, { username })
            this.formData.idCardFront = uploadRes
            uni.hideLoading()
            uni.showToast({
              title: '上传成功',
              icon: 'success'
            })
          } catch (error) {
            uni.hideLoading()
            console.error('上传身份证正面照失败:', error)
          }
        }
      })
    },

    // 删除身份证正面照
    deleteIdCardFront() {
      this.formData.idCardFront = ''
    },

    // 上传身份证反面照
    uploadIdCardBack() {
      uni.chooseImage({
        count: 1,
        sizeType: ['compressed'],
        sourceType: ['album', 'camera'],
        success: async (res) => {
          const tempFilePath = res.tempFilePaths[0]

          uni.showLoading({
            title: '上传中...'
          })

          try {
            const info: any = userState.userInfo
            const username = info?.username || 'user'
            const uploadRes = await upload('/file/upload/runner-auth', tempFilePath, { username })
            this.formData.idCardBack = uploadRes
            uni.hideLoading()
            uni.showToast({
              title: '上传成功',
              icon: 'success'
            })
          } catch (error) {
            uni.hideLoading()
            console.error('上传身份证反面照失败:', error)
          }
        }
      })
    },

    // 删除身份证反面照
    deleteIdCardBack() {
      this.formData.idCardBack = ''
    },

    // 验证身份证号（支持15位和18位）
    validateIdCard(idCard: string): boolean {
      const trimmedIdCard = idCard.trim()
      if (trimmedIdCard.length === 15) {
        const reg15 = /^[1-9]\d{5}\d{2}(0[1-9]|1[0-2])(0[1-9]|[12]\d|3[01])\d{3}$/
        return reg15.test(trimmedIdCard)
      } else if (trimmedIdCard.length === 18) {
        const reg18 = /^[1-9]\d{5}(18|19|20)\d{2}(0[1-9]|1[0-2])(0[1-9]|[12]\d|3[01])\d{3}[\dXx]$/
        return reg18.test(trimmedIdCard)
      }
      return false
    },

    // 提交申请
    async handleSubmit() {
      if (!this.checkRunnerAccess()) {
        return
      }
      // 验证
      if (!this.formData.realName.trim()) {
        uni.showToast({
          title: '请输入真实姓名',
          icon: 'none'
        })
        return
      }

      if (!this.formData.idCard.trim()) {
        uni.showToast({
          title: '请输入身份证号',
          icon: 'none'
        })
        return
      }

      if (!this.validateIdCard(this.formData.idCard)) {
        uni.showToast({
          title: '身份证号格式不正确，请输入15位或18位身份证号',
          icon: 'none'
        })
        return
      }

      if (!this.formData.idCardFront) {
        uni.showToast({
          title: '请上传身份证正面照',
          icon: 'none'
        })
        return
      }

      if (!this.formData.idCardBack) {
        uni.showToast({
          title: '请上传身份证反面照',
          icon: 'none'
        })
        return
      }

      this.submitting = true
      try {
        await applyRunnerAuth(this.formData)
        uni.showToast({
          title: '提交成功，请等待审核',
          icon: 'success'
        })
        setTimeout(() => {
          uni.navigateBack()
        }, 1500)
      } catch (error) {
        console.error('提交认证申请失败:', error)
        uni.showToast({
          title: '提交失败，请重试',
          icon: 'none'
        })
      } finally {
        this.submitting = false
      }
    }
  }
}
</script>

<style scoped>
