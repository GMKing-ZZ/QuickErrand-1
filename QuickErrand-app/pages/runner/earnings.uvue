.total-card {
  padding: 40rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 50%, #60a5fa 100%);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.total-label {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.total-amount {
  display: block;
  font-size: 60rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 30rpx;
}

.total-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.info-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.info-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.info-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.info-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 收益详情：横向三项 */
.detail-row-card {
  margin-bottom: 30rpx;
  padding: 28rpx 20rpx;
  background: #ffffff;
  border-radius: 18rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.detail-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #6b7280;
}

.detail-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.detail-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e5e7eb;
}

/* 操作按钮 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  height: 90rpx;
  border-radius: 45rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

