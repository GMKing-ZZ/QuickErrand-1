<template>
  <view class="earnings-container">
    <!-- 导航栏 -->
    <view class="navbar">
      <view class="back-btn" @click="goBack">
        <text class="back-icon">←</text>
      </view>
      <text class="nav-title">我的收益</text>
      <view class="placeholder"></view>
    </view>

    <!-- 加载中 -->
    <view v-if="loading" class="loading-wrapper">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 收益统计 -->
    <view v-else class="content">
      <!-- 总收益卡片 -->
      <view class="total-card">
        <text class="total-label">总收益（元）</text>
        <text class="total-amount">{{ statistics.totalEarnings || '0.00' }}</text>
        <view class="total-info">
          <view class="info-item">
            <text class="info-label">今日收益</text>
            <text class="info-value">¥{{ statistics.todayEarnings || '0.00' }}</text>
          </view>
          <view class="info-divider"></view>
          <view class="info-item">
            <text class="info-label">本月收益</text>
            <text class="info-value">¥{{ statistics.monthEarnings || '0.00' }}</text>
          </view>
        </view>
      </view>

      <!-- 收益详情：可提现金额 / 待结算 / 已结算 同一行展示 -->
      <view class="detail-row-card">
        <view class="detail-item">
          <text class="detail-label">可提现金额</text>
          <text class="detail-amount">¥{{ statistics.withdrawableAmount || '0.00' }}</text>
        </view>
        <view class="detail-divider"></view>
        <view class="detail-item">
          <text class="detail-label">待结算</text>
          <text class="detail-amount">¥{{ statistics.pendingEarnings || '0.00' }}</text>
        </view>
        <view class="detail-divider"></view>
        <view class="detail-item">
          <text class="detail-label">已结算</text>
          <text class="detail-amount">¥{{ statistics.settledEarnings || '0.00' }}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-section">
        <button class="action-btn primary" @click="goToWithdrawal">
          <text class="btn-text">申请提现</text>
        </button>
        <button class="action-btn secondary" @click="goToDetails">
          <text class="btn-text">收益明细</text>
        </button>
        <button class="action-btn secondary" @click="goToWithdrawalRecords">
          <text class="btn-text">提现记录</text>
        </button>
      </view>
    </view>
  </view>
</template>

<script>
import { getEarningsStatistics } from '@/common/api/runner.uts'
import { userState } from '@/store/user.uts'

export default {
  data() {
    return {
      loading: true,
      statistics: {} as any
    }
  },
  onLoad() {
    this.checkRunnerAccess()
  },
  onShow() {
    // 页面显示时刷新数据
    this.checkRunnerAccess()
  },
  methods: {
    goBack() {
      uni.navigateBack()
    },

    checkRunnerAccess() {
      const info: any = userState.userInfo
      if (!info || info.userType !== 2) {
        uni.showModal({
          title: '提示',
          content: '当前账号不是跑腿员，无法查看跑腿员收益',
          showCancel: false,
          success: () => {
            uni.navigateBack()
          }
        })
        return
      }
      this.loadStatistics()
    },

    async loadStatistics() {
      this.loading = true
      try {
        this.statistics = await getEarningsStatistics()
      } catch (error) {
        console.error('获取收益统计失败:', error)
        uni.showToast({
          title: '加载失败，请重试',
          icon: 'none'
        })
      } finally {
        this.loading = false
      }
    },

    goToWithdrawal() {
      uni.navigateTo({
        url: '/pages/runner/withdrawal'
      })
    },

    goToDetails() {
      uni.navigateTo({
        url: '/pages/runner/earnings-details'
      })
    },

    goToWithdrawalRecords() {
      uni.navigateTo({
        url: '/pages/runner/withdrawal-records'
      })
    }
  }
}
</script>

<style scoped>
