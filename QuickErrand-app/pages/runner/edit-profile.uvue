.header-bg {
  position: relative;
  height: 280rpx;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 50%, #60a5fa 100%);
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(37, 99, 235, 0.15);
}

.wave {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 200%;
  height: 100rpx;
  background: #f9fafb;
  border-radius: 50% 50% 0 0;
  transform: translateX(-25%);
}

/* 导航栏 */
.navbar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 60rpx 30rpx 20rpx;
  z-index: 10;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  flex-shrink: 0;
  z-index: 11;
}

.back-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
  z-index: 10;
  white-space: nowrap;
}

.placeholder {
  width: 64rpx;
  flex-shrink: 0;
  margin-left: auto;
}

/* 头像区域 */
.avatar-section {
  position: relative;
  margin: -80rpx 30rpx 40rpx;
  display: flex;
  justify-content: center;
}

.avatar-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  border: 6rpx solid #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.2);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 100rpx;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
}

.avatar-text {
  font-size: 80rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
}

.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
  border-radius: 100rpx;
}

.avatar-wrapper:active .avatar-mask {
  opacity: 1;
}

.camera-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.edit-tip {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.avatar-label {
  font-size: 28rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

/* 表单内容 */
.form-content {
  padding: 0 30rpx;
}

.form-group {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(37, 99, 235, 0.08);
  margin-bottom: 30rpx;
}

.group-title {
  font-size: 28rpx;
  color: #6b7280;
  padding: 24rpx 30rpx 12rpx;
  font-weight: 500;
}

.form-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 30rpx;
  border-bottom: 1rpx solid #f3f4f6;
  min-height: 100rpx;
  box-sizing: border-box;
  transition: background 0.3s;
}

.form-item:active {
  background: #f9fafb;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
  width: 200rpx;
  min-width: 200rpx;
}

.form-label-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  line-height: 1;
  display: flex;
  align-items: center;
  width: 36rpx;
  text-align: center;
}

.form-label {
  font-size: 32rpx;
  color: #1f2937;
  font-weight: 500;
  flex-shrink: 0;
  white-space: nowrap;
  display: flex;
  align-items: center;
}

.form-input {
  flex: 1;
  font-size: 32rpx;
  color: #1f2937;
  text-align: right;
  min-width: 0;
  padding: 0;
  margin-left: 0;
}

.form-value-wrapper {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
  margin-left: 0;
}

.form-value {
  font-size: 32rpx;
  color: #1f2937;
  margin-right: 16rpx;
